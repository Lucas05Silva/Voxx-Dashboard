# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase (for real mode)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Data source switch
# demo     -> mock data
# supabase -> Supabase tables
# rbx      -> RBXSoft ISP Web Services
NEXT_PUBLIC_DATA_SOURCE="demo"

# Legacy compatibility switch (optional)
# true  -> always demo
# false -> follow NEXT_PUBLIC_DATA_SOURCE
NEXT_PUBLIC_DEMO_MODE="true"

# RBXSoft ISP (Web Services REST + JSON)
# Base URL goes here (homologacao or producao):
# e.g. https://rbx-hml.voxx.local or https://rbx.voxx.com.br
NEXT_PUBLIC_RBX_BASE_URL="https://rbx-host.example"

# RBX API access key goes here:
NEXT_PUBLIC_RBX_ACCESS_KEY="your-rbx-access-key"

# Optional environment marker for routing/observability
NEXT_PUBLIC_RBX_ENVIRONMENT="homologacao"
